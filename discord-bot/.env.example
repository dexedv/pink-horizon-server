# ── Discord ──────────────────────────────────────────────────────────────────
# Bot-Token: https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=dein_bot_token_hier

# Application-ID: https://discord.com/developers/applications → General → Application ID
DISCORD_CLIENT_ID=deine_client_id_hier

# Deine Discord-Server-ID (Rechtsklick auf Server → ID kopieren)
DISCORD_GUILD_ID=deine_guild_id_hier

# ── Minecraft Server ──────────────────────────────────────────────────────────
# Öffentliche Adresse (für Anzeige in Embeds)
MC_ADDRESS=play.pinkhorizon.fun

# Proxy-Host (Docker-Servicename oder IP)
PROXY_HOST=velocity
PROXY_PORT=25565

# Backend-Server (Docker-Servicenamen)
SMASH_HOST=smash
SMASH_PORT=25570
SURVIVAL_HOST=survival
SURVIVAL_PORT=25565
LOBBY_HOST=lobby
LOBBY_PORT=25565

# ── Datenbank (für /stats Befehl) ────────────────────────────────────────────
DB_HOST=ph-mysql
DB_PORT=3306
DB_USER=pinkhorizon
DB_PASS=dein_db_passwort
DB_NAME=pinkhorizon
