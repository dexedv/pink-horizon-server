# ── Maven Build-Output ────────────────────────────────────────────────
plugins/*/target/

# ── Server-JARs ───────────────────────────────────────────────────────
servers/*/server.jar
servers/*/paper-*.jar
proxy/velocity-*.jar
proxy/server.jar

# ── Welten ────────────────────────────────────────────────────────────
# Lobby + Survival: nur Nether/End ignorieren (Overworld wird für Disaster-Recovery getrackt)
servers/survival/world_nether/
servers/survival/world_the_end/
servers/minigames/world_nether/
servers/minigames/world_the_end/
servers/lobby/world_nether/
servers/lobby/world_the_end/
servers/lobby/world_backup/

# SkyBlock: Welten NIE in Git – werden durch Docker-Volume gesichert
# (git pull würde sonst Spieler-Inseln und Spawn-Welt überschreiben!)
servers/skyblock/world/
servers/skyblock/world_nether/
servers/skyblock/world_the_end/
servers/skyblock/skyblock_world/

# ── Automatisch generierte World-Metadaten (ändern sich bei jedem Start) ──
# Ausnahme: Survival level.dat wird getrackt (für World-Recovery)
# SkyBlock level.dat ist durch das skyblock/world/ + skyblock/skyblock_world/ Ignore bereits abgedeckt
servers/lobby/world/level.dat
servers/lobby/world/level.dat_old
servers/smash/world/level.dat
servers/smash/world/level.dat_old
servers/generators/island-template/level.dat_old
**/level.dat_old_mcr
**/data/raids.dat
**/data/random_sequences.nbt
**/uid.dat

# ── Session-Lock (läuft gerade) ───────────────────────────────────────
**/session.lock

# ── Logs & Crash-Reports ──────────────────────────────────────────────
**/logs/
**/crash-reports/

# ── Paper-Caches ──────────────────────────────────────────────────────
**/.paper-remapped/
**/cache/
**/libraries/
**/versions/

# ── Temporäre / automatisch generierte Dateien ───────────────────────
*.tmp
eula.txt
usercache.json
**/ops.json
**/whitelist.json
**/banned-*.json

# ── Spielerdaten (live auf dem Server, nie überschreiben!) ────────────
servers/*/plugins/PH-Survival/ranks.yml
servers/*/plugins/PH-Survival/claims.yml
servers/*/plugins/PH-Survival/jobs.yml
servers/*/plugins/PH-Survival/upgrades.yml
servers/*/plugins/PH-Survival/homes.yml
servers/*/plugins/PH-Survival/warps.yml
servers/*/plugins/PH-Lobby/ranks.yml
servers/*/plugins/PH-SkyBlock/islands.yml
servers/*/plugins/PH-Core/data.db

# SkyBlock Plugin-Laufzeitdaten (werden in-game gesetzt, nicht durch git verwalten)
servers/skyblock/plugins/PH-SkyBlock/config.yml
servers/skyblock/plugins/PH-SkyBlock/npcs.yml
servers/skyblock/plugins/PH-SkyBlock/holograms.yml

# ── MySQL-Datenbankdateien (Laufzeitdaten, nie in Git) ────────────────
data/mysql/

# ── Secrets ───────────────────────────────────────────────────────────
.env

# ── IDE ───────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
servers/survival/plugins/PH-Survival/pending_spawn_paste.yml

# ── Playwright MCP (Browser-Automation Logs, nicht committen) ─────────
.playwright-mcp/

# ── Generators: Per-Spieler-Inseln (zur Laufzeit generiert) ──────────
servers/generators/island_*/
servers/generators/world/
servers/generators/world_nether/
servers/generators/world_the_end/
servers/generators/plugins/PH-Generators/generators.db

# island-template level.dat explizit tracken (wird für Weltladung benötigt)
!servers/generators/island-template/level.dat
!servers/generators/island-template/level.dat_old

# island-template: Spielerdaten und Forge-Dateien nicht tracken
servers/generators/island-template/players/
servers/generators/island-template/serverconfig/
servers/generators/island-template/spsSettings.json
servers/generators/island-template/DIM1/
servers/generators/island-template/DIM-1/
servers/generators/island-template/dimensions/
